---
/**
 * Timeline index page — shows available historical periods.
 *
 * CRZ Layer 1: static HTML with period links + custom period form.
 * No JavaScript needed. The custom period form submits via GET,
 * and the server redirects to /timeline/YYYY-MM.
 */

import { getAvailablePeriods } from "@/features/timeline/data/timeline";
import { ui } from "@/i18n/ui";
import BaseLayout from "@/shared/layout/BaseLayout.astro";

// Current year-month for max attribute and validation (e.g. "2026-03")
const now = new Date();
const maxPeriod = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;

// Handle custom period form submission (GET ?period=YYYY-MM)
const periodParam = Astro.url.searchParams.get("period")?.trim();
let periodError: string | null = null;
if (periodParam) {
	const isValidFormat = /^\d{4}-\d{2}$/.test(periodParam);
	const month = isValidFormat
		? Number.parseInt(periodParam.split("-")[1], 10)
		: 0;
	const isValidMonth = month >= 1 && month <= 12;
	const isInRange = periodParam >= "1890-01" && periodParam <= maxPeriod;

	if (isValidFormat && isValidMonth && isInRange) {
		return Astro.redirect(`/timeline/${periodParam}`);
	}
	periodError = ui.timeline.customPeriodInvalid(periodParam);
}

const periods = getAvailablePeriods();

// Group periods by era
const eras = new Map<string, typeof periods>();
for (const period of periods) {
	const existing = eras.get(period.era);
	if (existing) {
		existing.push(period);
	} else {
		eras.set(period.era, [period]);
	}
}
---

<BaseLayout
	title={ui.timeline.title}
	description="明治から令和まで、議会の議事録と出版物を時系列で重ね合わせて閲覧します"
>
	<div class="timeline-index">
		<header class="page-header">
			<h1 class="page-title">{ui.timeline.title}</h1>
			<p class="page-description">{ui.timeline.description}</p>
		</header>

		<section class="custom-period-section card">
			<h2 class="custom-period-title">{ui.timeline.customPeriod}</h2>
			<p class="custom-period-hint">{ui.timeline.customPeriodHint}</p>
			{periodError && (
				<div class="warning-container">
					<p class="warning-message">{periodError}</p>
				</div>
			)}
			<form method="GET" action="/timeline" class="custom-period-form">
				<label for="custom-period" class="visually-hidden"
					>{ui.timeline.customPeriod}</label
				>
				<div class="custom-period-field">
					<input
						id="custom-period"
						type="month"
						name="period"
						class="outlined"
						min="1890-01"
						max={maxPeriod}
						placeholder="1947-05"
						pattern="\d{4}-\d{2}"
						value={periodError ? periodParam : ""}
						required
					>
					<button type="submit" class="filled">{ui.timeline.go}</button>
				</div>
			</form>
		</section>

		<p class="form-label">{ui.timeline.selectPeriod}</p>

		{Array.from(eras).map(([era, eraPeriodsGroup]) => (
			<section class="era-section">
				<h2 class="era-title">{era}</h2>
				<ul class="period-grid">
					{eraPeriodsGroup.map((period) => (
						<li>
							<a
								href={`/timeline/${period.value}`}
								class="card period-card"
							>
								<span class="period-value">{period.value}</span>
								<span class="period-label">{period.label}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</BaseLayout>

<style>
.timeline-index {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-8);
}

.page-header {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-2);
}

.page-title {
	font-size: var(--md-sys-typescale-headline-large-size);
	line-height: var(--md-sys-typescale-headline-large-line-height);
	font-weight: var(--md-sys-typescale-headline-large-weight);
	color: var(--md-sys-color-on-surface);
}

.page-description {
	font-size: var(--md-sys-typescale-body-large-size);
	line-height: var(--md-sys-typescale-body-large-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

.custom-period-section {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-2);
}

.custom-period-title {
	font-size: var(--md-sys-typescale-title-medium-size);
	font-weight: var(--md-sys-typescale-title-medium-weight);
	line-height: var(--md-sys-typescale-title-medium-line-height);
	color: var(--md-sys-color-on-surface);
}

.custom-period-hint {
	font-size: var(--md-sys-typescale-body-small-size);
	line-height: var(--md-sys-typescale-body-small-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

.custom-period-form {
	margin-top: var(--md-sys-spacing-1);
}

.custom-period-field {
	display: flex;
	gap: var(--md-sys-spacing-2);
	max-width: 320px;
}

.custom-period-field input {
	flex: 1;
}

.form-label {
	font-size: var(--md-sys-typescale-body-medium-size);
	color: var(--md-sys-color-on-surface-variant);
}

.era-section {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-4);
}

.era-title {
	font-size: var(--md-sys-typescale-title-large-size);
	line-height: var(--md-sys-typescale-title-large-line-height);
	font-weight: var(--md-sys-typescale-title-large-weight);
	color: var(--md-sys-color-primary);
	padding-bottom: var(--md-sys-spacing-2);
	border-bottom: 2px solid var(--md-sys-color-primary);
}

.period-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	gap: var(--md-sys-spacing-3);
	list-style: none;
	padding: 0;
}

.period-card {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-1);
	text-decoration: none;
	color: inherit;
	transition:
		box-shadow 0.2s,
		background-color 0.2s;
}

.period-card:hover {
	box-shadow: var(--md-sys-elevation-2);
	background: var(--md-sys-color-surface-container);
}

.period-value {
	font-size: var(--md-sys-typescale-title-medium-size);
	font-weight: var(--md-sys-typescale-title-medium-weight);
	color: var(--md-sys-color-primary);
}

.period-label {
	font-size: var(--md-sys-typescale-body-medium-size);
	line-height: var(--md-sys-typescale-body-medium-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

@media (max-width: 599px) {
	.page-title {
		font-size: var(--md-sys-typescale-headline-medium-size);
		line-height: var(--md-sys-typescale-headline-medium-line-height);
	}

	.period-grid {
		grid-template-columns: 1fr;
	}

	.custom-period-field {
		flex-direction: column;
	}
}
</style>
