---
/**
 * Timeline index page — shows available historical periods.
 *
 * CRZ Layer 1: static HTML with period links, no JavaScript needed.
 * Users select a period, then enter a keyword on the period detail page.
 */

import { ui } from "@/i18n/ui";
import BaseLayout from "@/shared/layout/BaseLayout.astro";

const { getAvailablePeriods } = await import(
	"@/features/timeline/data/timeline"
);
const periods = getAvailablePeriods();

// Group periods by era
const eras = new Map<string, typeof periods>();
for (const period of periods) {
	const existing = eras.get(period.era);
	if (existing) {
		existing.push(period);
	} else {
		eras.set(period.era, [period]);
	}
}
---

<BaseLayout
	title={ui.timeline.title}
	description="明治から令和まで、議会の議事録と出版物を時系列で重ね合わせて閲覧します"
>
	<div class="timeline-index">
		<header class="page-header">
			<h1 class="page-title">{ui.timeline.title}</h1>
			<p class="page-description">{ui.timeline.description}</p>
		</header>

		<p class="form-label">{ui.timeline.selectPeriod}</p>

		{Array.from(eras).map(([era, eraPeriodsGroup]) => (
			<section class="era-section">
				<h2 class="era-title">{era}</h2>
				<ul class="period-grid">
					{eraPeriodsGroup.map((period) => (
						<li>
							<a
								href={`/timeline/${period.value}`}
								class="card period-card"
							>
								<span class="period-value">{period.value}</span>
								<span class="period-label">{period.label}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</BaseLayout>

<style>
.timeline-index {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-8);
}

.page-header {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-2);
}

.page-title {
	font-size: var(--md-sys-typescale-headline-large-size);
	line-height: var(--md-sys-typescale-headline-large-line-height);
	font-weight: var(--md-sys-typescale-headline-large-weight);
	color: var(--md-sys-color-on-surface);
}

.page-description {
	font-size: var(--md-sys-typescale-body-large-size);
	line-height: var(--md-sys-typescale-body-large-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

.form-label {
	font-size: var(--md-sys-typescale-body-medium-size);
	color: var(--md-sys-color-on-surface-variant);
}

.era-section {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-4);
}

.era-title {
	font-size: var(--md-sys-typescale-title-large-size);
	line-height: var(--md-sys-typescale-title-large-line-height);
	font-weight: var(--md-sys-typescale-title-large-weight);
	color: var(--md-sys-color-primary);
	padding-bottom: var(--md-sys-spacing-2);
	border-bottom: 2px solid var(--md-sys-color-primary);
}

.period-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	gap: var(--md-sys-spacing-3);
	list-style: none;
	padding: 0;
}

.period-card {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-1);
	text-decoration: none;
	color: inherit;
	transition:
		box-shadow 0.2s,
		background-color 0.2s;
}

.period-card:hover {
	box-shadow: var(--md-sys-elevation-2);
	background: var(--md-sys-color-surface-container);
}

.period-value {
	font-size: var(--md-sys-typescale-title-medium-size);
	font-weight: var(--md-sys-typescale-title-medium-weight);
	color: var(--md-sys-color-primary);
}

.period-label {
	font-size: var(--md-sys-typescale-body-medium-size);
	line-height: var(--md-sys-typescale-body-medium-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

@media (max-width: 599px) {
	.page-title {
		font-size: var(--md-sys-typescale-headline-medium-size);
		line-height: var(--md-sys-typescale-headline-medium-line-height);
	}

	.period-grid {
		grid-template-columns: 1fr;
	}
}
</style>
