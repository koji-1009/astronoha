---
/**
 * Attribution component for NDL API source citation.
 * Required on every search result page per NDL usage terms.
 */

import { ui } from "@/i18n/ui";
---

<p class="attribution">
	<a
		href="https://github.com/koji-1009/astronoha"
		target="_blank"
		rel="noopener noreferrer"
		>GitHub</a
	>
	｜ {ui.attribution.source}
	<a
		href="https://kokkai.ndl.go.jp/api.html"
		target="_blank"
		rel="noopener noreferrer"
		>{ui.attribution.ndl}</a
	>（<a
		href="https://kokkai.ndl.go.jp/api.html"
		target="_blank"
		rel="noopener noreferrer"
		>{ui.attribution.kokkaiApi}</a
	>・<a
		href="https://teikokugikai-i.ndl.go.jp/"
		target="_blank"
		rel="noopener noreferrer"
		>{ui.attribution.teikokuApi}</a
	>・<a
		href="https://ndlsearch.ndl.go.jp/"
		target="_blank"
		rel="noopener noreferrer"
		>{ui.attribution.ndlSearchApi}</a
	>）
</p>

<style>
.attribution {
	font-size: var(--md-sys-typescale-body-small-size);
	line-height: var(--md-sys-typescale-body-small-line-height);
	letter-spacing: var(--md-sys-typescale-body-small-tracking);
	color: var(--md-sys-color-on-surface-variant);
}

.attribution a {
	color: var(--md-sys-color-primary);
	text-decoration: none;
}

.attribution a:hover {
	text-decoration: underline;
}
</style>
