---
import { ui } from "@/i18n/ui";

interface Props {
	books: Array<{
		title: string;
		link: string;
		author: string;
		publisher: string;
		date: string;
		identifier: string;
		thumbnailUrl: string;
	}>;
}

const { books } = Astro.props;
---

<div class="book-carousel">
	<h3 class="book-carousel-heading">{ui.bookCarousel.title}</h3>
	{books.length === 0 ? (
		<p class="book-carousel-empty">{ui.bookCarousel.noData}</p>
	) : (
		<div class="book-carousel-scroll">
			{books.map((book) => (
				<a
					href={book.link}
					target="_blank"
					rel="noopener noreferrer"
					class="book-carousel-card-link"
				>
					<div class="book-carousel-card card">
						<div class="book-carousel-thumbnail">
							<img
								src={book.thumbnailUrl}
								alt={ui.a11y.bookCover(book.title)}
								class="book-carousel-img"
								data-identifier={book.identifier}
								loading="lazy"
								width="180"
								height="120"
							/>
							<span class="book-carousel-fallback" aria-hidden="true">No Image</span>
						</div>
						<p class="book-carousel-title">{book.title}</p>
						<p class="book-carousel-author">{book.author}</p>
						<p class="book-carousel-date">{book.date}</p>
					</div>
				</a>
			))}
		</div>
	)}
</div>

<script>
document.addEventListener(
	"load",
	(e) => {
		const target = e.target;
		if (
			target instanceof HTMLImageElement &&
			target.classList.contains("book-carousel-img")
		) {
			target.style.display = "block";
			const fallback = target
				.closest(".book-carousel-thumbnail")
				?.querySelector(".book-carousel-fallback");
			if (fallback instanceof HTMLElement) {
				fallback.style.display = "none";
			}
		}
	},
	true,
);
</script>

<style>
.book-carousel-heading {
	font-size: var(--md-sys-typescale-title-medium-size);
	font-weight: var(--md-sys-typescale-title-medium-weight);
	line-height: var(--md-sys-typescale-title-medium-line-height);
	color: var(--md-sys-color-on-surface);
	margin-bottom: var(--md-sys-spacing-3);
}

.book-carousel-empty {
	color: var(--md-sys-color-on-surface-variant);
	font-size: var(--md-sys-typescale-body-medium-size);
	line-height: var(--md-sys-typescale-body-medium-line-height);
}

.book-carousel-scroll {
	display: flex;
	gap: var(--md-sys-spacing-3);
	overflow-x: auto;
	scroll-snap-type: x mandatory;
	padding-bottom: var(--md-sys-spacing-2);
}

.book-carousel-card-link {
	display: block;
	flex-shrink: 0;
	width: 180px;
	scroll-snap-align: start;
	text-decoration: none;
	color: inherit;
}

.book-carousel-card {
	height: 100%;
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-2);
	padding: var(--md-sys-spacing-3);
	transition: box-shadow 0.2s;
}

.book-carousel-thumbnail {
	width: 100%;
	height: 120px;
	display: flex;
	align-items: center;
	justify-content: center;
	background-color: var(--md-sys-color-surface-container-high);
	border-radius: var(--md-sys-shape-corner-small);
	overflow: hidden;
}

.book-carousel-img {
	display: none;
	max-width: 100%;
	max-height: 100%;
	object-fit: contain;
}

.book-carousel-fallback {
	color: var(--md-sys-color-on-surface-variant);
	font-size: var(--md-sys-typescale-label-small-size);
}

.book-carousel-title {
	font-size: var(--md-sys-typescale-title-small-size);
	font-weight: var(--md-sys-typescale-title-small-weight);
	line-height: var(--md-sys-typescale-title-small-line-height);
	color: var(--md-sys-color-on-surface);
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.book-carousel-author {
	font-size: var(--md-sys-typescale-body-small-size);
	line-height: var(--md-sys-typescale-body-small-line-height);
	color: var(--md-sys-color-on-surface-variant);
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.book-carousel-date {
	font-size: var(--md-sys-typescale-label-small-size);
	line-height: var(--md-sys-typescale-label-small-line-height);
	color: var(--md-sys-color-on-surface-variant);
}
</style>
