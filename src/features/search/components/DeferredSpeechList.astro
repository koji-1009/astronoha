---
/**
 * Server Island: speech list for a single source (kokkai or teikoku).
 *
 * Used in "both" mode to render each source independently with its own
 * pagination. Deferred via server:defer so the page shell returns immediately.
 */

import { searchSpeeches as searchKokkaiSpeeches } from "@/features/search/data/kokkai";
import { searchSpeeches as searchTeikokuSpeeches } from "@/features/search/data/teikoku";
import { ui } from "@/i18n/ui";
import Pagination from "@/shared/components/Pagination.astro";
import SpeechCard from "@/shared/components/SpeechCard.astro";
import { truncateSpeech } from "@/shared/lib/format";

interface Props {
	keyword: string;
	source: "kokkai" | "teikoku";
	currentPage: number;
	baseUrl: string;
	pageParam: string;
	from?: string;
	until?: string;
}

const { keyword, source, currentPage, baseUrl, pageParam, from, until } =
	Astro.props;

const pageSize = 10;
const startRecord = (currentPage - 1) * pageSize + 1;

const label =
	source === "kokkai" ? ui.search.targetKokkai : ui.search.targetTeikoku;

let speeches: Array<{
	speechID: string;
	nameOfHouse: string;
	nameOfMeeting: string;
	issue: string;
	date: string | null;
	speaker: string;
	speech: string;
}> = [];
let totalRecords = 0;
let errorMessage: string | null = null;

try {
	const searchFn =
		source === "kokkai" ? searchKokkaiSpeeches : searchTeikokuSpeeches;
	const result = await searchFn({
		keyword,
		maximumRecords: pageSize,
		startRecord,
		from,
		until,
	});
	speeches = result.speechRecord ?? [];
	totalRecords = result.numberOfRecords ?? 0;
} catch (error) {
	const errorFn =
		source === "kokkai"
			? ui.error.kokkaiSearchFailed
			: ui.error.teikokuSearchFailed;
	errorMessage = errorFn(
		error instanceof Error ? error.message : ui.error.unknownDetail,
	);
}

const totalPages = Math.ceil(totalRecords / pageSize);
---

<section class="source-section">
	<h2 class="section-title">
		{label}（{ui.search.resultsCount(totalRecords)}）
	</h2>

	{errorMessage && (
		<div class="warning-container card">
			<p class="warning-message">{errorMessage}</p>
		</div>
	)}

	{speeches.length > 0 && (
		<ol class="speech-list">
			{speeches.map((speech) => (
				<li>
					<SpeechCard
						href={`/word/${encodeURIComponent(keyword)}/${encodeURIComponent(speech.speechID)}`}
						nameOfHouse={speech.nameOfHouse}
						nameOfMeeting={speech.nameOfMeeting}
						issue={speech.issue}
						date={speech.date}
						speaker={speech.speaker}
						excerpt={truncateSpeech(speech.speech)}
					/>
				</li>
			))}
		</ol>
	)}

	{speeches.length === 0 && !errorMessage && (
		<p class="no-results">{ui.search.noResults(keyword)}</p>
	)}

	<Pagination
		currentPage={currentPage}
		totalPages={totalPages}
		baseUrl={baseUrl}
		pageParam={pageParam}
	/>
</section>

<style>
.source-section {
	padding-bottom: var(--md-sys-spacing-6);
	border-bottom: 1px solid var(--md-sys-color-outline-variant);
}

.speech-list {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-3);
	list-style: none;
	padding: 0;
}

.no-results {
	font-size: var(--md-sys-typescale-body-medium-size);
	color: var(--md-sys-color-on-surface-variant);
}
</style>
