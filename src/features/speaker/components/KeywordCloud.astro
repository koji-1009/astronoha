---
import { ui } from "@/i18n/ui";

interface Props {
	keywords: Array<{ word: string; count: number }>;
	speakerName: string;
}

const { keywords, speakerName } = Astro.props;

const maxCount =
	keywords.length > 0 ? Math.max(...keywords.map((k) => k.count)) : 0;
const minCount =
	keywords.length > 0 ? Math.min(...keywords.map((k) => k.count)) : 0;

function getFontSize(count: number): number {
	if (maxCount === minCount) return 20;
	const ratio = (count - minCount) / (maxCount - minCount);
	return 12 + ratio * 28;
}

function getWeight(count: number): number {
	if (maxCount === minCount) return 400;
	const ratio = (count - minCount) / (maxCount - minCount);
	return ratio > 0.5 ? 500 : 400;
}
---

{keywords.length === 0 ? (
	<p class="keyword-cloud-empty">{ui.keywordCloud.noData}</p>
) : (
	<div class="keyword-cloud">
		<h3 class="keyword-cloud-title">{ui.keywordCloud.title(speakerName)}</h3>
		<div class="keyword-cloud-container">
			{keywords.map((kw) => (
				<a
					href={`/word/${encodeURIComponent(kw.word)}`}
					class="keyword-cloud-link"
					title={`${kw.word}: ${kw.count}回`}
					style={`font-size: ${getFontSize(kw.count)}px; font-weight: ${getWeight(kw.count)};`}
				>
					{kw.word}
				</a>
			))}
		</div>
	</div>
)}

<style>
.keyword-cloud-empty {
	color: var(--md-sys-color-on-surface-variant);
	font-size: var(--md-sys-typescale-body-medium-size);
	line-height: var(--md-sys-typescale-body-medium-line-height);
}

.keyword-cloud-title {
	font-size: var(--md-sys-typescale-title-medium-size);
	font-weight: var(--md-sys-typescale-title-medium-weight);
	line-height: var(--md-sys-typescale-title-medium-line-height);
	color: var(--md-sys-color-on-surface);
	margin-bottom: var(--md-sys-spacing-4);
}

.keyword-cloud-container {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: var(--md-sys-spacing-2) var(--md-sys-spacing-3);
	padding: var(--md-sys-spacing-4);
	background-color: var(--md-sys-color-surface-container-low);
	border-radius: var(--md-sys-shape-corner-medium);
}

.keyword-cloud-link {
	line-height: 1.3;
	color: var(--md-sys-color-primary);
	text-decoration: none;
	transition: color 0.15s;
	padding: var(--md-sys-spacing-1);
}

.keyword-cloud-link:hover {
	color: var(--md-sys-color-primary);
	text-decoration: underline;
}
</style>
