---
/**
 * TimelineScroll — Vertical timeline of speeches and publications.
 *
 * CRZ Layer 1-2: Pure server-rendered. Filter state comes from URL query params.
 * No client-side JavaScript required.
 *
 * Desktop (840px+): Speeches left, publications right of a center timeline line.
 * Mobile: Single column with line on the left.
 * Entries are grouped by date with date headers on the timeline.
 */

import { ui } from "@/i18n/ui";
import { formatDate } from "@/shared/lib/format";
import type { TimelineEntry } from "../data/timeline";

interface Props {
	entries: Array<TimelineEntry>;
	keyword: string;
	period: string;
	filter: "all" | "speeches" | "publications";
}

const { entries, keyword, period, filter } = Astro.props;

const totalCount = entries.length;

const filteredEntries = entries.filter((entry) => {
	if (filter === "speeches") return entry.type === "speech";
	if (filter === "publications") return entry.type === "publication";
	return true;
});

const sortedEntries = [...filteredEntries].sort((a, b) =>
	a.date.localeCompare(b.date),
);

const speechCount = entries.filter((e) => e.type === "speech").length;
const publicationCount = entries.filter((e) => e.type === "publication").length;

// Group sorted entries by date for date headers
const dateGroups: Array<{
	date: string;
	formatted: string;
	entries: TimelineEntry[];
}> = [];
for (const entry of sortedEntries) {
	const dateKey = entry.date || "";
	const last = dateGroups[dateGroups.length - 1];
	if (last && last.date === dateKey) {
		last.entries.push(entry);
	} else {
		dateGroups.push({
			date: dateKey,
			formatted: dateKey ? formatDate(dateKey) : ui.timeline.unknownDate,
			entries: [entry],
		});
	}
}

/**
 * Build filter URL preserving the existing `q` query param.
 */
function filterHref(target: "all" | "speeches" | "publications"): string {
	const base = `/timeline/${period}`;
	const params = new URLSearchParams();
	if (keyword) params.set("q", keyword);
	if (target !== "all") params.set("filter", target);
	const qs = params.toString();
	return qs ? `${base}?${qs}` : base;
}
---

{entries.length === 0 ? (
	<p class="empty-message">{ui.timeline.noData}</p>
) : (
	<div class="timeline-scroll">
		{/* Filter tabs */}
		<div class="timeline-header">
			<div class="filter-links">
				<a
					href={filterHref("all")}
					class:list={["filter-link", { "filter-link--active": filter === "all" }]}
				>
					{ui.timeline.filterAll(totalCount)}
				</a>
				<a
					href={filterHref("speeches")}
					class:list={["filter-link", { "filter-link--active": filter === "speeches" }]}
				>
					<span class="filter-dot filter-dot--speech" />
					{ui.timeline.filterSpeeches(speechCount)}
				</a>
				<a
					href={filterHref("publications")}
					class:list={["filter-link", { "filter-link--active": filter === "publications" }]}
				>
					<span class="filter-dot filter-dot--publication" />
					{ui.timeline.filterPublications(publicationCount)}
				</a>
			</div>
		</div>

		{/* Lane labels — desktop only */}
		<div class="lane-labels" aria-hidden="true">
			<span class="lane-label lane-label--left">{ui.timeline.typeSpeech}</span>
			<span class="lane-label lane-label--right">{ui.timeline.typePublication}</span>
		</div>

		{/* Timeline */}
		<div class="timeline-container">
			<div class="timeline-line" />

			{dateGroups.map((group) => (
				<div class="date-group">
					<div class="date-header">
						<span class="date-label">{group.formatted}</span>
					</div>

					{group.entries.map((entry) => {
						const isSpeech = entry.type === "speech";
						const href = isSpeech
							? `/word/${encodeURIComponent(keyword)}/${entry.speechId}`
							: entry.link;

						return (
							<div class:list={[
								"timeline-entry",
								isSpeech ? "timeline-entry--left" : "timeline-entry--right",
							]}>
								<div class:list={[
									"timeline-dot",
									isSpeech ? "timeline-dot--speech" : "timeline-dot--publication",
								]} />

								<a
									href={href}
									{...(isSpeech ? {} : { target: "_blank", rel: "noopener noreferrer" })}
									class="entry-card-link"
								>
									<div class:list={[
										"card",
										"entry-card",
										isSpeech ? "entry-card--speech" : "entry-card--publication",
									]}>
										<span class:list={[
											"entry-type",
											isSpeech ? "entry-type--speech" : "entry-type--publication",
										]}>
											{isSpeech ? ui.timeline.typeSpeech : ui.timeline.typePublication}
										</span>
										<p class="entry-title">{entry.title}</p>
										{isSpeech && entry.speaker && (
											<p class="entry-meta">
												{entry.speaker}
												{entry.house ? ` (${entry.house})` : ""}
											</p>
										)}
										{!isSpeech && entry.author && (
											<p class="entry-meta">{entry.author}</p>
										)}
										{!isSpeech && (
											<p class="entry-external-hint">{ui.timeline.viewOnNdlSearch} ↗</p>
										)}
									</div>
								</a>
							</div>
						);
					})}
				</div>
			))}
		</div>

		{/* Summary */}
		<p class="timeline-summary">
			{ui.timeline.displayCount(filteredEntries.length, totalCount)}
		</p>
	</div>
)}

<style>
.empty-message {
	color: var(--md-sys-color-on-surface-variant);
	font-size: var(--md-sys-typescale-body-medium-size);
	line-height: var(--md-sys-typescale-body-medium-line-height);
}

.timeline-scroll {
	display: flex;
	flex-direction: column;
}

/* ── Filter tabs ── */

.timeline-header {
	margin-bottom: var(--md-sys-spacing-4);
}

.filter-links {
	display: flex;
	gap: var(--md-sys-spacing-2);
	flex-wrap: wrap;
}

.filter-link {
	display: inline-flex;
	align-items: center;
	gap: var(--md-sys-spacing-1);
	padding: var(--md-sys-spacing-1) var(--md-sys-spacing-3);
	border-radius: var(--md-sys-shape-corner-small);
	font-size: var(--md-sys-typescale-label-large-size);
	font-weight: var(--md-sys-typescale-label-large-weight);
	line-height: var(--md-sys-typescale-label-large-line-height);
	text-decoration: none;
	color: var(--md-sys-color-on-surface-variant);
	background: transparent;
	border: 1px solid var(--md-sys-color-outline);
	transition:
		background-color 0.2s,
		color 0.2s;
}

.filter-link:hover {
	background: var(--md-sys-color-surface-container-high);
}

.filter-link--active {
	background: var(--md-sys-color-secondary-container);
	color: var(--md-sys-color-on-secondary-container);
	border-color: transparent;
}

.filter-dot {
	display: inline-block;
	width: 8px;
	height: 8px;
	border-radius: var(--md-sys-shape-corner-full);
}

.filter-dot--speech {
	background-color: var(--md-sys-color-primary);
}

.filter-dot--publication {
	background-color: var(--md-sys-color-tertiary);
}

/* ── Lane labels (desktop only) ── */

.lane-labels {
	display: none;
}

/* ── Timeline container ── */

.timeline-container {
	position: relative;
	padding-left: var(--md-sys-spacing-8);
}

.timeline-line {
	position: absolute;
	left: var(--md-sys-spacing-3);
	top: 0;
	bottom: 0;
	width: 2px;
	background-color: var(--md-sys-color-outline-variant);
}

/* ── Date groups ── */

.date-group {
	padding-top: var(--md-sys-spacing-4);
}

.date-group:first-child {
	padding-top: 0;
}

.date-header {
	position: relative;
	z-index: 1;
	margin-bottom: var(--md-sys-spacing-3);
}

.date-label {
	display: inline-block;
	font-size: var(--md-sys-typescale-label-large-size);
	font-weight: var(--md-sys-typescale-label-large-weight);
	line-height: var(--md-sys-typescale-label-large-line-height);
	color: var(--md-sys-color-on-surface);
	background: var(--md-sys-color-surface-container);
	padding: var(--md-sys-spacing-1) var(--md-sys-spacing-3);
	border-radius: var(--md-sys-shape-corner-full);
}

/* ── Timeline entries ── */

.timeline-entry {
	position: relative;
	margin-bottom: var(--md-sys-spacing-3);
}

.timeline-dot {
	position: absolute;
	left: calc(-1 * var(--md-sys-spacing-8) + 7px);
	top: var(--md-sys-spacing-3);
	width: 12px;
	height: 12px;
	border-radius: var(--md-sys-shape-corner-full);
	border: 2px solid var(--md-sys-color-surface);
	z-index: 1;
}

.timeline-dot--speech {
	background-color: var(--md-sys-color-primary);
}

.timeline-dot--publication {
	background-color: var(--md-sys-color-tertiary);
}

/* ── Entry cards ── */

.entry-card-link {
	display: block;
	text-decoration: none;
	color: inherit;
}

.entry-card {
	display: flex;
	flex-direction: column;
	gap: var(--md-sys-spacing-1);
	transition: box-shadow 0.2s;
}

.entry-card:hover {
	box-shadow: var(--md-sys-elevation-2);
}

.entry-card--speech {
	border-left: 3px solid var(--md-sys-color-primary);
}

.entry-card--publication {
	border-left: 3px solid var(--md-sys-color-tertiary);
}

.entry-type {
	display: inline-block;
	font-size: var(--md-sys-typescale-label-small-size);
	font-weight: var(--md-sys-typescale-label-small-weight);
	line-height: var(--md-sys-typescale-label-small-line-height);
	padding: 1px var(--md-sys-spacing-2);
	border-radius: var(--md-sys-shape-corner-extra-small);
	width: fit-content;
}

.entry-type--speech {
	color: var(--md-sys-color-on-primary-container);
	background: var(--md-sys-color-primary-container);
}

.entry-type--publication {
	color: var(--md-sys-color-on-tertiary-container);
	background: var(--md-sys-color-tertiary-container);
}

.entry-title {
	font-size: var(--md-sys-typescale-body-large-size);
	line-height: var(--md-sys-typescale-body-large-line-height);
	color: var(--md-sys-color-on-surface);
}

.entry-meta {
	font-size: var(--md-sys-typescale-body-small-size);
	line-height: var(--md-sys-typescale-body-small-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

.entry-external-hint {
	font-size: var(--md-sys-typescale-label-small-size);
	font-weight: var(--md-sys-typescale-label-small-weight);
	color: var(--md-sys-color-tertiary);
}

/* ── Summary ── */

.timeline-summary {
	margin-top: var(--md-sys-spacing-4);
	font-size: var(--md-sys-typescale-body-small-size);
	line-height: var(--md-sys-typescale-body-small-line-height);
	color: var(--md-sys-color-on-surface-variant);
}

/* ── Desktop: left/right alternating layout ── */

@media (min-width: 840px) {
	.lane-labels {
		display: flex;
		justify-content: space-between;
		padding: 0 var(--md-sys-spacing-6);
		margin-bottom: var(--md-sys-spacing-3);
	}

	.lane-label {
		font-size: var(--md-sys-typescale-label-large-size);
		font-weight: var(--md-sys-typescale-label-large-weight);
		line-height: var(--md-sys-typescale-label-large-line-height);
		letter-spacing: var(--md-sys-typescale-label-large-tracking);
		color: var(--md-sys-color-on-surface-variant);
		text-transform: uppercase;
	}

	.lane-label--left {
		color: var(--md-sys-color-primary);
	}

	.lane-label--right {
		color: var(--md-sys-color-tertiary);
	}

	.timeline-container {
		padding-left: 0;
	}

	.timeline-line {
		left: 50%;
		transform: translateX(-50%);
	}

	/* Date header centered on the line */
	.date-header {
		display: flex;
		justify-content: center;
	}

	.date-label {
		border: 1px solid var(--md-sys-color-outline-variant);
	}

	/* Entries positioned left or right */
	.timeline-entry {
		display: flex;
	}

	.timeline-entry--left {
		justify-content: flex-end;
		padding-right: calc(50% + var(--md-sys-spacing-5));
	}

	.timeline-entry--right {
		justify-content: flex-start;
		padding-left: calc(50% + var(--md-sys-spacing-5));
	}

	/* Dot always centered on the line */
	.timeline-dot {
		left: calc(50% - 6px);
		top: var(--md-sys-spacing-3);
	}

	/* Speech cards: border on the right (facing the line) */
	.entry-card--speech {
		border-left: none;
		border-right: 3px solid var(--md-sys-color-primary);
	}

	/* Publication cards: border-left stays (facing the line) */
}

@media (max-width: 599px) {
	.filter-links {
		gap: var(--md-sys-spacing-1);
	}

	.filter-link {
		padding: var(--md-sys-spacing-1) var(--md-sys-spacing-2);
		font-size: var(--md-sys-typescale-label-medium-size);
	}
}
</style>
